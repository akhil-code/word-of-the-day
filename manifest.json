{
    "manifest_version": 3,
    "name": "Word of the Day: Vocabulary & Definitions - words.url2.at",
    "version": "1.0.3",
    "description": "Free daily English vocabulary in your toolbar: word, definition, and part of speech - no account, no ads, no payments",
    "permissions": [],
    "action": {
      "default_popup": "popup/popup.html",
      "default_icon": {
        "16": "icons/16.png",
        "24": "icons/24.png",
        "32": "icons/32.png"
      }
    },
    "icons": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self';"
    }
  }